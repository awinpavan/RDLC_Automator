          <KeepTogether>true</KeepTogether>
          <Paragraphs>
          <Paragraph>
          <TextRuns>
          <TextRun>
          <Value>is provided to the hotel no later than on the day of the booking. If this condition is</Value>
          <Style>
          <FontSize>6pt</FontSize>
          <FontWeight>Normal</FontWeight>
          </Style>
          </TextRun>
          </TextRuns>
          <Style />
